import os
os.system("cls")

avioes = [] * 4
assentos = [0] * 4
reservas = [] # Lista para armazenar dicionários (aviao, passageiro)

while True:
    print("\n1: Cadastrar Aviões | 2: Assentos | 3: Reservar passagem | 4: Por Avião | 5: Por Passageiro | 6: Finalizar a execução do algoritimo.")
    opção = input("Escolha uma das opções a seguir: ")

    if opção == "1":
        avioes = [input(f"ID Avião {i+1}: ") for i in range(4)]
    
    elif opção == "2":
        assentos = [int(input(f"Assentos p/ {avioes[i]}: ")) for i in range(4)]

    elif opção == "3":
        if len(reservas) >= 20:
            print(f"Limite esgotado!")
            continue
        
        id_busca = input("ID do Avião: ")
        if id_busca in avioes:
            idx = avioes.index(id_busca)
            if assentos[idx] > 0:
                nome = input("Nome: ")
                reservas.append({"aviao": id_busca, "nome": nome})
                assentos[idx] -= 1
                print(f"Reserva realizada com sucesso!")
            else:
                print("Não há assentos disponíveis para este avião!")
        else:
            print(f"Este avião não existe!")

    elif opção ==  "4":
        id_busca = input("Consultar Avião: ")
        encontrados = [r['nome'] for r in reservas if r['aviao'] == id_busca]
        print(f"Passageiros: {encontrados}" if encontrados else "Não há reservas realizadas para este avião!")

    elif opção == "5":
        nome_busca = input("Nome do Passageiro: ")
        voos = [r['aviao'] for r in reservas if r['nome'] == nome_busca]
        print(f"Aviões: {voos}" if voos else "Não há reservas realizadas para este passageiro!")

    elif opção == "6":
        print(f"Algoritimo finalizado com sucesso!")
        break